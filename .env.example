# Legacy single-endpoint OpenAI-compatible config
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4.1-mini

# General named endpoint config
# SDG_ENDPOINT__<NAME>__BASE_URL=...
# SDG_ENDPOINT__<NAME>__API_KEY=...
# SDG_ENDPOINT__<NAME>__API_KEY_ENV=...
# SDG_ENDPOINT__<NAME>__DEFAULT_MODEL=...
# SDG_ENDPOINT__<NAME>__MAX_CONCURRENCY=...
# SDG_ENDPOINT__<NAME>__MAX_RETRIES=...
# SDG_ENDPOINT__<NAME>__MIN_BACKOFF_SECONDS=...
# SDG_ENDPOINT__<NAME>__MAX_BACKOFF_SECONDS=...
# SDG_ENDPOINT__<NAME>__TIMEOUT_SECONDS=...

SDG_ENDPOINT__OPENAI__BASE_URL=https://api.openai.com/v1
SDG_ENDPOINT__OPENAI__API_KEY_ENV=OPENAI_API_KEY
SDG_ENDPOINT__OPENAI__DEFAULT_MODEL=gpt-4.1-mini
SDG_ENDPOINT__OPENAI__MAX_CONCURRENCY=4
SDG_ENDPOINT__OPENAI__MAX_RETRIES=4

SDG_ENDPOINT__LOCAL_VLLM__BASE_URL=http://localhost:8000/v1
SDG_ENDPOINT__LOCAL_VLLM__API_KEY=dummy
SDG_ENDPOINT__LOCAL_VLLM__DEFAULT_MODEL=local/default
